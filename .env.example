DATABASE_URL=postgresql://postgres:password@localhost:5432/merclex_intel
E2E_DATABASE_URL=postgresql://postgres:password@localhost:5432/merclex_intel_e2e
# Optional: only needed if your main DATABASE_URL user cannot CREATE DATABASE
E2E_DATABASE_ADMIN_URL=postgresql://postgres:password@localhost:5432/postgres
E2E_USE_DOCKER=0
E2E_DOCKER_IMAGE=postgres:16-alpine
E2E_DOCKER_DB_NAME=merclex_e2e
E2E_DOCKER_USER=postgres
E2E_DOCKER_PASSWORD=postgres
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini
OPENAI_FALLBACK_MODEL=gpt-5.4
NEWS_API_KEY=your_newsapi_key_here
GNEWS_API_KEY=your_gnews_key_here
PEOPLE_DATA_LABS_API_KEY=your_pdl_key_here
OPENCORPORATES_API_KEY=your_opencorporates_key_here
NODE_ENV=development
PORT=3000
BATCH_CONCURRENCY=5
PROVIDER_TIMEOUT_MS=10000
NEWS_LOOKBACK_DAYS=30
LOG_LEVEL=info
MERCLEX_MOCK_EXTERNAL_PROVIDERS=0
