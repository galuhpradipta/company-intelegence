{
  "name": "merclex-company-intelligence",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "tsc -b && vp build",
    "lint": "eslint .",
    "preview": "vp preview",
    "prepare": "vp config",
    "test": "vp test",
    "server:dev": "tsx watch server/index.ts",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm server:dev\"",
    "dev:all:e2e": "concurrently \"VITE_API_PROXY_TARGET=http://localhost:3300 pnpm dev -- --port 4173 --strictPort\" \"PORT=3300 pnpm server:dev\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "start": "node dist/server/index.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:integration": "tsx scripts/run-e2e-integration.ts",
    "test:e2e:integration:headed": "tsx scripts/run-e2e-integration.ts --headed",
    "test:e2e:integration:ui": "tsx scripts/run-e2e-integration.ts --ui",
    "test:e2e:integration:docker": "tsx scripts/run-e2e-integration.ts --docker",
    "test:e2e:integration:docker:headed": "tsx scripts/run-e2e-integration.ts --docker --headed",
    "test:e2e:integration:docker:ui": "tsx scripts/run-e2e-integration.ts --docker --ui"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hono/node-server": "^1.14.0",
    "@hono/trpc-server": "^0.3.4",
    "@hono/zod-validator": "^0.5.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.75.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "csv-parse": "^5.6.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0",
    "jose": "^5.10.0",
    "openai": "^5.0.0",
    "p-limit": "^6.2.0",
    "pg": "^8.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "zod": "^3.25.55",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.13"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
